HOST_LAN_IP=192.168.1.100
FORGEJO_HTTP_PORT=3000
FORGEJO_SSH_PORT=2222
# Memory limits (auto-calculated by generate-passwords.sh; override if needed)
#FORGEJO_APP_MEMORY_LIMIT=512m
#FORGEJO_POSTGRES_MEMORY_LIMIT=1g

POSTGRES_DB=forgejo
POSTGRES_USER=forgejo
# DB password: generated in forgejo/secrets/postgres_password by generate-passwords.sh

DOCKER_VOLUME_DIR=/var/lib/forgejo
FORGEJO_DATA_VOLUME=${DOCKER_VOLUME_DIR}/data
FORGEJO_DB_VOLUME=${DOCKER_VOLUME_DIR}/db
