# Test .env for the new Nextcloud stack in migration tests.
# Credentials intentionally differ from mock AIO to validate remapping.
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_TRUSTED_DOMAINS=localhost nextcloud_app
NEXTCLOUD_PRIMARY_DOMAIN=localhost
NEXTCLOUD_APPS=
COMPOSE_PROFILES=
NEXTCLOUD_DATA_DIR=/mnt/ncdata
HOST_LAN_IP=127.0.0.1
NEXTCLOUD_LAN_PORT=18889
DEFAULT_PHONE_REGION=US
MAINTENANCE_WINDOW_START=3
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_NAME=test@localhost
SMTP_PASSWORD=test
MAIL_FROM_ADDRESS=noreply
MAIL_DOMAIN=localhost
TALK_STUN_SERVER=localhost:5349
TALK_TURN_SERVER=localhost:5349
TALK_TURN_SCHEMES=turn
TALK_TURN_PROTOCOLS=udp
TALK_TURN_SECRET=test-turn-secret
TALK_SIGNALING_SERVER=https://localhost/signaling
TALK_SIGNALING_SECRET=test-signal-secret
COLLABORA_URL=https://localhost
COLLABORA_WOPI_ALLOWLIST=
WHITEBOARD_JWT_SECRET=test-wb-secret
WHITEBOARD_PUBLIC_URL=https://localhost/whiteboard
WHITEBOARD_MAX_UPLOAD_FILE_SIZE=10
HP_SHARED_KEY=test-hp-key
TIMEZONE=UTC
POSTGRES_DB=nextcloud_test_db
POSTGRES_USER=oc_nextcloud
POSTGRES_HOST=nextcloud_postgres
REDIS_HOST=nextcloud_redis
NEXTCLOUD_PROXY_NETWORK_SUBNET=172.28.0.0/24
NEXTCLOUD_INTERNAL_NETWORK_SUBNET=172.29.0.0/24
DOCKER_VOLUME_DIR=/tmp/nc-test-volumes
NEXTCLOUD_APP_VOLUME=/tmp/nc-test-volumes/app
NEXTCLOUD_DATA_VOLUME=/tmp/nc-test-volumes/data
NEXTCLOUD_DB_VOLUME=/tmp/nc-test-volumes/db
NEXTCLOUD_REDIS_VOLUME=/tmp/nc-test-volumes/redis
HARP_CERTS_VOLUME=/tmp/nc-test-volumes/harp_certs
CLAMAV_DB_VOLUME=/tmp/nc-test-volumes/clamav_db
ELASTICSEARCH_DATA_VOLUME=/tmp/nc-test-volumes/elasticsearch
ES_HEAP_SIZE=512m
