CLOUDFLARE_TUNNEL_TOKEN=<your-tunnel-token-here>

HOST_LAN_IP=192.168.1.100

DOCKER_VOLUME_DIR=/var/lib/nginx-proxy-manager
NPM_DATA_VOLUME=${DOCKER_VOLUME_DIR}/data
NPM_LETSENCRYPT_VOLUME=${DOCKER_VOLUME_DIR}/letsencrypt

# Memory limits (auto-calculated by generate-passwords.sh; override if needed)
#NPM_MEMORY_LIMIT=256m
#CLOUDFLARED_MEMORY_LIMIT=128m