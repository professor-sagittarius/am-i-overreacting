HOST_LAN_IP=192.168.1.100
GITEA_HTTP_PORT=3000
GITEA_SSH_PORT=2222
# Memory limits (auto-calculated by generate-passwords.sh; override if needed)
#GITEA_APP_MEMORY_LIMIT=512m
#GITEA_POSTGRES_MEMORY_LIMIT=1g

POSTGRES_DB=gitea
POSTGRES_USER=gitea
# DB password: generated in gitea/secrets/postgres_password by generate-passwords.sh

DOCKER_VOLUME_DIR=/var/lib/gitea
GITEA_DATA_VOLUME=${DOCKER_VOLUME_DIR}/data
GITEA_DB_VOLUME=${DOCKER_VOLUME_DIR}/db
